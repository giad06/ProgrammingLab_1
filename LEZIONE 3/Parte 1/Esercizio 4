# Esercizio 4

def elem_comune_liste(A, B):
    for elemento in A:
        if elemento in B:
            return True
    return False

lista1 = [1, 2, 3]
lista2 = [3, 4, 5]
    
if elem_comune_liste(lista1, lista2):
    print("Le liste hanno elementi in comune")
else:
    print("Le liste non hanno elementi in comune")